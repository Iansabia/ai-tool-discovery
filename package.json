{
  "name": "ai-tools-discovery",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "node ./node_modules/typescript/bin/tsc -b && node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "lint": "node ./node_modules/eslint/bin/eslint.js .",
    "test": "node ./node_modules/vitest/vitest.mjs",
    "test:run": "node ./node_modules/vitest/vitest.mjs run",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "lint:no-direct-localstorage": "! grep -RInE 'localStorage\\.(set|get|remove|clear)Item' src/ --exclude-dir=src/lib --exclude=src/lib/storage.ts 2>/dev/null"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "^4.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.11.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.14.2",
    "shadcn": "^4.5.0",
    "simple-icons": "^16.18.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "jsdom": "^25.0.0",
    "typescript": "~5.6.0",
    "typescript-eslint": "^8.11.0",
    "vite": "^6.0.0",
    "vitest": "^1.6.0"
  }
}
